---
// Footer component - shared across all pages
---

<footer class="panel panel-blue">
	<div class="footer-content">
		<div class="footer-section">
			<h2>About TeachTools</h2>
			<p>
				TeachTools provides simple, free tools and utilities to help
				teachers and team leaders manage classroom and team activities
				efficiently. Create seating charts, generate balanced teams, and
				pick students randomly with no repeats. All tools on TeachTools
				are free to use, no login required. More tools coming soon!
			</p>
		</div>

		<div class="footer-section">
			<h3>Tools</h3>
			<ul>
				<li>
					<a href="/seating-chart-generator"
						>Seating Chart Generator</a
					>
				</li>
				<li><a href="/team-generator">Team Generator</a></li>
				<li>
					<a href="/random-student-picker">Random Name Picker</a>
				</li>
			</ul>
		</div>

		<div class="footer-section">
			<h3>Contact</h3>
			<p>
				Questions or feedback? Email
				<a href="mailto:info@teach-tools.org">info@teach-tools.org</a>.
			</p>
		</div>
	</div>

	<div class="footer-bottom">
		<p>
			&copy; {new Date().getFullYear()} TeachTools. All rights reserved.
		</p>
	</div>
</footer>

<style>
	footer {
		padding: 2rem 1rem;
		margin-top: 3rem;
		border-radius: 0;
	}

	.footer-content {
		max-width: 1200px;
		margin: 0 auto 2rem;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
	}

	.footer-section h3 {
		font-size: 1rem;
		margin-bottom: 1rem;
	}

	.footer-section p {
		color: var(--blue-dark);
		line-height: 1.6;
		margin: 0;
		font-size: 0.95rem;
	}

	.footer-section ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-section li {
		margin-bottom: 0.5rem;
	}

	.footer-section a {
		color: var(--blue);
		text-decoration: none;
	}

	.footer-section a:hover {
		color: var(--blue-dark);
		text-decoration: underline;
	}

	.footer-bottom {
		margin: 0 auto;
		text-align: center;
	}

	.footer-bottom p {
		color: var(--blue-dark);
		margin: 0;
		font-size: 0.9rem;
	}
</style>
