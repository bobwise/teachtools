---
import PageLayout from "../layouts/PageLayout.astro";
import "../styles/team-generator.css";
---

<PageLayout title="Team Generator - TeachTools">
    <h1>Team Generator</h1>
    <div class="team-app">
        <div class="panel">
            <h2>Team Setup</h2>

            <label for="studentNames">Names</label>
            <textarea id="studentNames" placeholder="Alice
Bob
Charlie..."
            ></textarea>
            <p style="font-size: 0.9rem; color: #666; margin-bottom: 1.5rem;">
                <span id="studentCount">0 team members</span>
            </p>

            <div class="radio-group">
                <div class="radio-option">
                    <input
                        type="radio"
                        id="modeCount"
                        name="teamMode"
                        value="count"
                        checked
                    />
                    <label for="modeCount">Number of groups</label>
                </div>
                <input
                    type="number"
                    id="numGroups"
                    min="1"
                    max="20"
                    value="4"
                />
            </div>

            <div class="radio-group">
                <div class="radio-option">
                    <input
                        type="radio"
                        id="modeSize"
                        name="teamMode"
                        value="size"
                    />
                    <label for="modeSize">Team members per group</label>
                </div>
                <input
                    type="number"
                    id="groupSize"
                    min="1"
                    max="20"
                    value="4"
                    disabled
                />
            </div>

            <div
                style="margin-bottom: 1.5rem; padding: 1rem; background: white; border-radius: 4px;"
            >
                <label
                    for="includeLeaders"
                    style="display: flex; align-items: center; cursor: pointer; margin: 0;"
                >
                    <input
                        type="checkbox"
                        id="includeLeaders"
                        style="margin-right: 0.75rem; cursor: pointer; width: 18px; height: 18px;"
                    />
                    <span>Include team leaders 👑</span>
                </label>
            </div>

            <div
                id="separateLeaderControls"
                class="hidden-control"
                style="margin-bottom: 1.5rem; padding: 1rem; background: white; border-radius: 4px;"
            >
                <label
                    for="useSeparateLeaderList"
                    style="display: flex; align-items: center; cursor: pointer; margin: 0;"
                >
                    <input
                        type="checkbox"
                        id="useSeparateLeaderList"
                        disabled
                        style="margin-right: 0.75rem; cursor: pointer; width: 18px; height: 18px;"
                    />
                    <span>Use separate leader list</span>
                </label>
            </div>

            <div id="leaderNamesContainer" class="hidden-control">
                <label for="leaderNames">Leader Names</label>
                <textarea id="leaderNames" placeholder="Alice
Bob
Charlie..."
                ></textarea>
                <p
                    style="font-size: 0.9rem; color: #666; margin-bottom: 1.5rem;"
                >
                    <span id="leaderCount">0 leaders</span>
                </p>
            </div>

            <div class="btn-group">
                <button type="button" class="btn-primary" id="generateTeamsBtn">
                    Generate Teams
                </button>
                <button type="button" class="btn-tertiary" id="shuffleBtn">
                    🔀 Shuffle
                </button>
            </div>
        </div>

        <div id="teamsWrapper" style="display: none;">
            <div class="teams-wrapper">
                <p
                    id="teamsTip"
                    style="display: none; font-size: 0.95rem; color: #555; margin-bottom: 1rem;"
                >
                    Tip: Drag and drop between teams
                </p>
                <div id="teamsContainer" class="teams-container">
                    <div class="empty-state">Generate teams to see results</div>
                </div>
            </div>
        </div>
    </div>

    <script src="../scripts/team-generator.js"></script>
</PageLayout>
