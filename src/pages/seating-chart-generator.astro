---
import PageLayout from "../layouts/PageLayout.astro";
import { DEFAULT_NAMES } from "../constants/default-names.js";
import "../styles/seating-chart.css";

const defaultNamesText = DEFAULT_NAMES.join("\n");
---

<PageLayout
	title="Seating Chart Generator - TeachTools"
	description="Quickly create and print classroom seating charts. Adjust rows and columns, configure desk layout, and print seating charts ready for class. All tools on TeachTools are free to use, no payment or login required."
>
	<h1>Seating Chart Generator</h1>
	<div class="app seating-app">
		<div class="panel panel-blue">
			<h2>Chart Setup</h2>
			<div class="names-section">
				<div class="clear-container">
					<label for="names" id="namesLabel">Names</label>
					<button
						type="button"
						class="btn-tertiary btn-small hidden"
						id="clear">Clear</button
					>
				</div>
				<textarea id="names">{defaultNamesText}</textarea>
			</div>

			<div class="controls-section controls hidden">
				<div id="arrowsContainer">
					<button class="numChange btn-tertiary" id="narrower"
						>➡️⬅️</button
					>
					<button class="numChange btn-tertiary" id="wider"
						>⬅️➡️</button
					>
					<button class="numChange btn-tertiary" id="taller"
						>⬇️</button
					>
					<button class="numChange btn-tertiary" id="shorter"
						>⬆️</button
					>
				</div>

				<div class="pod-size-toggle hidden">
					<input id="rows" type="number" min="1" max="8" value="1" />
					<input id="cols" type="number" min="1" max="8" value="1" />
					<input id="podSize" type="hidden" value="1" />
					<button
						type="button"
						role="button"
						class="pod-option active btn-tertiary"
						data-pod-size="1"
						title="Pod size 1"
					>
						<div class="seat">
							<div class="pod">
								<div class="desk">
									<div class="desk-seat" data-desk="0"></div>
								</div>
							</div>
						</div>
					</button>
					<button
						type="button"
						role="button"
						class="pod-option btn-tertiary"
						data-pod-size="2"
						title="Pod size 2"
					>
						<div class="seat">
							<div class="pod">
								<div class="desk">
									<div class="desk-seat" data-desk="0"></div>
								</div>
								<div class="desk">
									<div class="desk-seat" data-desk="1"></div>
								</div>
							</div>
						</div>
					</button>
					<button
						type="button"
						role="button"
						class="pod-option btn-tertiary"
						data-pod-size="4"
						title="Pod size 4"
					>
						<div class="seat">
							<div class="pod pod-square">
								<div class="desk">
									<div class="desk-seat" data-desk="0"></div>
								</div>
								<div class="desk">
									<div class="desk-seat" data-desk="1"></div>
								</div>
								<div class="desk">
									<div class="desk-seat" data-desk="2"></div>
								</div>
								<div class="desk">
									<div class="desk-seat" data-desk="3"></div>
								</div>
							</div>
						</div>
					</button>
				</div>
				<div class="action-buttons">
					<button
						type="button"
						class="hidden btn-tertiary"
						id="sort"
						title="Sort">🔤 Sort</button
					>
					<button
						type="button"
						class="hidden btn-tertiary"
						id="shuffle"
						title="Shuffle">🔀 Shuffle</button
					>
					<button
						type="button"
						class="hidden btn-tertiary"
						id="print"
						title="Print">🖨️ Print</button
					>
				</div>
			</div>
		</div>

		<div id="chartWrapper" class="panel hidden" role="main">
			<div id="dragLabel">Tip: Drag and drop to rearrange desks.</div>
			<div id="printArea">
				<div id="boardLabel">Board</div>
				<div id="chart" class="chart"></div>
			</div>
		</div>
	</div>

	<script src="../scripts/seating-app.js"></script>
</PageLayout>
