---
import PageLayout from "../layouts/PageLayout.astro";
import { DEFAULT_NAMES } from "../constants/default-names.js";
import "../styles/random-picker.css";

const defaultNamesText = DEFAULT_NAMES.join("\n");
---

<PageLayout
    title="Random Name Picker - TeachTools"
    description="Pick names at random in seconds with optional no-repeat fairness mode so every participant gets a turn before repeats. Make sure every name gets called on equally. Great for class participation, presentations, school activities, and games. All tools on TeachTools are free to use, no payment or login required."
>
    <h1>Random Name Picker</h1>
    <div class="app random-picker-app">
        <div class="panel">
            <div class="names-section">
                <div class="clear-container">
                    <label for="names" id="namesLabel">Names</label>
                    <button
                        type="button"
                        class="btn-tertiary btn-small hidden"
                        id="clear">Clear</button
                    >
                </div>
                <textarea id="names">{defaultNamesText}</textarea>
            </div>

            <div class="controls">
                <div class="checkbox-container">
                    <label for="includeLeaders">
                        <input type="checkbox" id="includeLeaders" />
                        <span
                            >Pick equally<p
                                style="margin: 0.5rem 0 0; color: #666; font-size: 0.75rem;"
                            >
                                No repeats until everyone is picked
                            </p></span
                        >
                    </label>
                </div>

                <button type="button" class="btn-primary" id="generateTeamsBtn">
                    Pick Next
                </button>
            </div>
        </div>

        <div id="pickerResult" class="panel hidden" role="main"></div>
    </div>

    <script src="../scripts/random-picker.js"></script>
</PageLayout>
