---
import PageLayout from "../layouts/PageLayout.astro";
import { DEFAULT_NAMES } from "../constants/default-names.js";
import "../styles/random-picker.css";

const defaultNamesText = DEFAULT_NAMES.join("\n");
---

<PageLayout title="Random Student Picker - TeachTools">
    <h1>Random Student Picker</h1>
    <div class="app random-picker-app">
        <div class="panel">
            <div class="names-section">
                <div id="clearContainer">
                    <label for="names" id="namesLabel">Names</label>
                    <button
                        type="button"
                        class="btn-tertiary btn-small hidden"
                        id="clear">Clear</button
                    >
                </div>
                <textarea id="names">{defaultNamesText}</textarea>
            </div>

            <div class="controls">
                <div
                    style="padding: 1rem; background: white; border-radius: 4px; width: 100%"
                >
                    <label
                        for="includeLeaders"
                        style="display: flex; align-items: center; cursor: pointer; margin: 0;"
                    >
                        <input
                            type="checkbox"
                            id="includeLeaders"
                            style="margin-right: 0.75rem; cursor: pointer; width: 18px; height: 18px;"
                        />
                        <span>No repeats</span>
                    </label>
                </div>

                <button type="button" class="btn-primary" id="generateTeamsBtn">
                    Pick Next
                </button>
            </div>
        </div>

        <div id="pickerResult" class="panel hidden" role="main"></div>
    </div>

    <script src="../scripts/random-picker.js"></script>
</PageLayout>
